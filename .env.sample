# ─────────────────────────────────────────────────────────────
# Omni-Agent — environment configuration
# Copy to `.env` and fill in values. All keys are case-insensitive.
# Every setting has a default (see app/core/config.py); only
# GEMINI_API_KEY is required for the agent to work.
# ─────────────────────────────────────────────────────────────

# --- App / server ---
APP_NAME="Omni-Agent"
ENV=development                 # development | production
DEBUG=True                      # enables uvicorn reload + DEBUG logging (app only)
THIRD_PARTY_LOG_LEVEL=WARNING   # floor for noisy libs (browser_use, crawl4ai, cdp_use)
HOST=127.0.0.1
PORT=8000
# Comma-separated list of allowed CORS origins (use * for all).
CORS_ORIGINS=*

# --- Database ---
# Async SQLAlchemy URL. Defaults to a local SQLite file under ./data.
# Postgres example: postgresql+asyncpg://user:pass@localhost:5432/harness
DATABASE_URL=sqlite+aiosqlite:///./data/harness.db

# --- Gemini (required) ---
GEMINI_API_KEY=your-gemini-api-key-here
# Stable model id (avoid the -preview alias). Multimodal + tool-calling.
GEMINI_MODEL=gemini-3.1-flash-lite
# Embedding model for hybrid corpus retrieval (corpus_search). Matryoshka-capable,
# so EMBEDDING_DIMENSIONS can truncate the vector for cheaper storage/compute.
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768        # embedding vector size (Matryoshka truncation)
EMBEDDING_BATCH_SIZE=100        # texts per embed_content request

# --- Agent / orchestration tuning (defaults tuned for accuracy + robustness) ---
# Iteration caps below accept 0 = NO LIMIT (run until answered / stopped / no progress).
MAX_AGENT_ITERATIONS=120        # max tool-loop turns for the single-agent chat (0 = unlimited)
MAX_PLAN_ITERATIONS=60          # max plan→execute→evaluate replans per research run (0 = unlimited)
MAX_PLAN_NODES=48               # hard cap on plan-graph nodes (runaway guard)
SUBAGENT_MAX_ITERATIONS=60      # max tool-loop turns per sub-agent (0 = unlimited)
SUBAGENT_MAX_REFLECTIONS=2      # self-critique rounds per sub-agent (gather-more loop)
MAX_SUBAGENT_DEPTH=3            # spawn_subagents nesting depth (0 = unlimited)
MAX_SPAWN_FANOUT=6              # max parallel children per spawn_subagents call (0 = unlimited)
MAX_SYNTHESIS_PARTS=8          # chain up to N streamed calls to finish a long answer (0 = unlimited)
BROWSER_USE_MAX_STEPS=24        # max steps for the browser_use agent
LLM_MAX_RETRIES=6               # retries on transient Gemini errors (429/5xx)
SESSION_TOKEN_BUDGET=0          # per-session token cap; 0 = unlimited

# --- Context sizes (Gemini 3 models have a 1M-token window — feed generously) ---
TOOL_EXCERPT_CHARS=48000        # excerpt size from parse_document/crawl_url/read_artifact
CRAWL_MAX_LINKS=150             # max structured links crawl_url returns for reference-following
SITEMAP_MAX_URLS=300            # max page URLs discover_sitemap returns
SITEMAP_DOC_BUDGET=40           # max sitemap/index docs discover_sitemap fetches
SITEMAP_TIMEOUT=12              # per-HTTP-request seconds for discover_sitemap
DOC_SECTION_CHARS=24000         # per-section text returned by doc_navigate

# --- Hybrid cross-document retrieval (corpus_search: embeddings + BM25 + RRF + rerank) ---
CORPUS_CHUNK_CHARS=1200         # target chunk size fed to the embedder
CORPUS_CHUNK_OVERLAP=200        # char overlap between adjacent chunks
CORPUS_CANDIDATE_K=30           # fused candidates considered before rerank
CORPUS_TOP_K=8                  # passages returned to the agent (default)
CORPUS_MAX_CHUNKS=6000          # safety cap on total chunks indexed per query
CORPUS_RRF_K=60                 # Reciprocal Rank Fusion damping constant
CORPUS_RERANK=true              # LLM-rerank the fused candidates for precision

HISTORY_MAX_TURNS=24            # prior conversation turns fed into planning
HISTORY_TURN_CHARS=8000         # per-turn char cap in the history preamble

# --- Web search & country context ---
SEARCH_REGION=wt-wt             # ddgs region: wt-wt worldwide/no bias; e.g. in-en, uk-en, us-en
# Global-default country: ISO-2 (IN) or name (India); shared with agents + pins browser
# locale/tz/geo. Per request the frontend overrides it with the visitor's browser country
# (X-User-Country header); this is the fallback when that's absent. Empty = no bias.
USER_COUNTRY=

# --- Robustness ---
TOOL_DEFAULT_TIMEOUT=360        # per-tool wall-clock limit (seconds)
CIRCUIT_TRIP_THRESHOLD=3        # failures before a flaky tool is disabled/session
SUBAGENT_VERIFY=True            # flag refusal/empty sub-agent answers as failed
# Hard cap on a loop's context before compaction. Effective threshold is
# min(this, a fraction of the active model's 1M-token window) — per app/core/models.py.
CONTEXT_COMPACT_CHARS=1500000
CONTEXT_KEEP_LAST_ROUNDS=8      # recent tool rounds kept verbatim when compacting

# --- Storage ---
DATA_DIR=data                   # root dir for uploads, downloads, parsed docs
